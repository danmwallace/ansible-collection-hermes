# Managed by Ansible — danmwallace.hermes.hermes_native
# Do not edit manually; changes will be overwritten on next run.
HERMES_HOME=/home/{{ hermes_native_user }}
ANTHROPIC_API_KEY={{ hermes_native_anthropic_api_key }}
API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT={{ hermes_native_api_server_port }}
API_SERVER_KEY={{ hermes_native_api_server_key }}
{% if hermes_native_dashboard_enabled %}
HERMES_DASHBOARD=1
HERMES_DASHBOARD_HOST=0.0.0.0
HERMES_DASHBOARD_PORT={{ hermes_native_dashboard_port }}
HERMES_DASHBOARD_BASIC_AUTH_USERNAME={{ hermes_native_dashboard_username }}
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD={{ hermes_native_dashboard_password }}
{% endif %}
PATH=/home/{{ hermes_native_user }}/.local/bin:/usr/local/bin:/usr/bin:/bin
