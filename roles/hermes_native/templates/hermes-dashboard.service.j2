# Managed by Ansible — danmwallace.hermes.hermes_native
[Unit]
Description=Hermes AI Agent Web Dashboard
After=hermes-agent.service
BindsTo=hermes-agent.service

[Service]
Type=simple
User={{ hermes_native_user }}
Group={{ hermes_native_user }}
WorkingDirectory=/home/{{ hermes_native_user }}
EnvironmentFile={{ hermes_native_env_file }}
ExecStart={{ hermes_native_install_dir }}/venv/bin/hermes dashboard \
    --host {{ hermes_native_dashboard_host | default('0.0.0.0') }} \
    --port {{ hermes_native_dashboard_port }} \
    --no-open \
    --insecure
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hermes-dashboard

[Install]
WantedBy=multi-user.target
